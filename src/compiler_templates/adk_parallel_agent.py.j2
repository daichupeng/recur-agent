"""{{ node.name }} — parallel orchestrator."""
from google.adk.agents import ParallelAgent
{%- for imp in child_imports %}
from {{ imp.module }} import {{ imp.symbol }}
{%- endfor %}
{%- if memory_node_id %}
from memory._bindings import BEFORE_CALLBACKS, AFTER_CALLBACKS
{%- endif %}

# Collect tools from all child agents (LlmAgent sub-agents expose tools via .tools)
_child_tools = []
{%- for imp in child_imports %}
if hasattr({{ imp.symbol }}, 'tools') and {{ imp.symbol }}.tools:
    _child_tools.extend({{ imp.symbol }}.tools)
{%- endfor %}

{{ node.name }}_agent = ParallelAgent(
    name="{{ node.name }}",
    sub_agents=[
{%- for imp in child_imports %}
        {{ imp.symbol }},
{%- endfor %}
    ],
{%- if memory_node_id %}
    before_agent_callback=BEFORE_CALLBACKS.get("{{ memory_node_id }}"),
    after_agent_callback=AFTER_CALLBACKS.get("{{ memory_node_id }}"),
{%- endif %}
{%- if child_imports %}
    tools=_child_tools if _child_tools else None,
{%- endif %}
)
