"""{{ node.name }} — atomic skill ({{ node.exec_type.value }})."""
# SANDBOX: This tool executes {{ node.exec_type.value }} logic.
# For production deployment, wrap this tool inside an ADK Code Executor or
# GKE/gVisor sandbox (AgentEngineCodeExecutor) to jail arbitrary code execution
# and external API calls from the host environment.
{%- set is_media = node.output_media_types %}
from google.adk.agents import LlmAgent
from google.adk.tools import FunctionTool
{%- if is_media %}
from google.adk.tools import ToolContext
from google.genai import types  # noqa: F401  (used by save_artifact in the body)
{%- endif %}
{%- if memory_node_id %}
from memory._bindings import BEFORE_CALLBACKS, AFTER_CALLBACKS
{%- endif %}


{% if is_media %}async {% endif %}def {{ node.name }}(
{%- for param_name, param_schema in (node.input_schema.get("properties") or {}).items() %}
    {{ param_name }}: {{ param_schema | pydantic_type }},
{%- endfor %}
{%- if is_media %}
    tool_context: ToolContext,
{%- endif %}
) -> dict:
    """{{ node.description }}

    Args:
{%- for param_name, param_schema in (node.input_schema.get("properties") or {}).items() %}
        {{ param_name }}: {{ param_schema.get("description", param_name) }}
{%- endfor %}
{%- if is_media %}

    Emits an artifact ({{ node.output_media_types | join(", ") }}) via
    tool_context.save_artifact; the returned dict includes `artifact_filename`.
{%- endif %}

    Returns:
        dict: {{ node.output_schema | schema_summary }}
    """
{%- if node.implementation %}
{{ node.implementation | indent_body }}
{%- else %}
    # TODO: Implement atomic skill — {{ node.name }}
    raise NotImplementedError("{{ node.name }} is not yet implemented")
{%- endif %}


_{{ node.name }}_tool = FunctionTool({{ node.name }})

{{ node.name }}_agent = LlmAgent(
    name="{{ node.name }}",
    model="{{ gemini_model }}",
    description="{{ node.description }}",
    instruction=(
        "Call the {{ node.name }} tool with these exact arguments:\n"
        "{{ node.input_schema | schema_summary }}\n"
        "Read each value from the session state key matching its name."
    ),
    tools=[_{{ node.name }}_tool],
{%- if memory_node_id %}
    before_agent_callback=BEFORE_CALLBACKS.get("{{ memory_node_id }}"),
    after_agent_callback=AFTER_CALLBACKS.get("{{ memory_node_id }}"),
{%- endif %}
)
