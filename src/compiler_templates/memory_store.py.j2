"""Shared markdown-backed store for persistent memory — auto-generated by recur-agent.

Each memory entity is a human-readable Markdown file (one GitHub-flavored table) under a
FIXED directory next to this package: <project>/memory_store/. That location is cwd-
independent and hard-wired here; set MEMORY_STORAGE_DIR only if you must relocate it.

Markdown is used (rather than a SQLite blob) so both humans and agents can read/edit the
stored state directly. DO NOT edit this file manually; re-run the recur-agent compiler.
"""
from __future__ import annotations

import json
import os
import threading
from pathlib import Path
from typing import Any, Optional

# ── Fixed default storage location ───────────────────────────────────────────
# <project>/memory_store/  — this file lives at <project>/memory/_store.py, so
# parent.parent is the project root. Fixed by design; env override is optional.
_DEFAULT_DIR = Path(__file__).resolve().parent.parent / "memory_store"

_LOCK = threading.RLock()


def storage_dir() -> Path:
    """Return the (created) memory storage directory. Fixed default, optional override."""
    d = Path(os.environ.get("MEMORY_STORAGE_DIR") or _DEFAULT_DIR)
    d.mkdir(parents=True, exist_ok=True)
    return d


def _esc(s: str) -> str:
    """Escape a cell so it cannot break the markdown table structure."""
    return s.replace("\\", "&#92;").replace("|", "&#124;").replace("\r", "").replace("\n", "&#10;")


def _unesc(s: str) -> str:
    return s.replace("&#10;", "\n").replace("&#124;", "|").replace("&#92;", "\\")


class MarkdownStore:
    """Generic markdown-table store for one entity. Config-driven; all IO lives here.

    File layout (<entity>.md):

        # <EntityName>

        _Backend: <BACKEND> — auto-managed by the product. Safe to read; edit with care._

        | col_a | col_b |
        | --- | --- |
        | v1 | v2 |
    """

    def __init__(
        self,
        entity: str,
        columns: list[str],
        field_types: dict[str, str],
        backend: str,
        pk: Optional[str] = None,
    ) -> None:
        self.entity = entity
        self.columns = columns or ["value"]
        self.field_types = field_types
        self.backend = backend
        self.pk = pk

    # ── paths / file scaffolding ─────────────────────────────────────────
    def _path(self) -> Path:
        # File name derives from the entity, lower-cased with safe chars.
        safe = "".join(c if c.isalnum() else "_" for c in self.entity).strip("_").lower() or "entity"
        return storage_dir() / f"{safe}.md"

    def _header(self) -> str:
        head = "| " + " | ".join(self.columns) + " |"
        sep = "| " + " | ".join("---" for _ in self.columns) + " |"
        return (
            f"# {self.entity}\n\n"
            f"_Backend: {self.backend} — auto-managed by the product. "
            f"Safe to read; edit with care._\n\n"
            f"{head}\n{sep}\n"
        )

    def ensure(self) -> None:
        """Create the entity file with an empty table if it does not exist."""
        with _LOCK:
            path = self._path()
            if not path.exists():
                path.write_text(self._header())

    # ── (de)serialisation ────────────────────────────────────────────────
    def _encode_cell(self, col: str, value: Any) -> str:
        if value is None:
            return ""
        if self.field_types.get(col) == "json":
            return _esc(json.dumps(value, ensure_ascii=False))
        return _esc(value if isinstance(value, str) else str(value))

    def _decode_cell(self, col: str, cell: str) -> Any:
        cell = _unesc(cell.strip())
        t = self.field_types.get(col, "str")
        if cell == "" and t != "str":
            return None
        try:
            if t == "int":
                return int(cell)
            if t == "float":
                return float(cell)
            if t == "bool":
                return cell.strip().lower() in ("true", "1", "yes")
            if t == "json":
                return json.loads(cell) if cell else None
        except (ValueError, TypeError):
            return cell
        return cell

    # ── read / write whole table ─────────────────────────────────────────
    def read_all(self) -> list[dict]:
        with _LOCK:
            path = self._path()
            if not path.exists():
                return []
            rows: list[dict] = []
            table_lines = [ln for ln in path.read_text().splitlines() if ln.lstrip().startswith("|")]
            if len(table_lines) < 2:
                return []
            header = [c.strip() for c in table_lines[0].strip().strip("|").split("|")]
            for line in table_lines[2:]:  # skip header + separator
                cells = [c for c in line.strip().strip("|").split("|")]
                if len(cells) != len(header):
                    continue
                rows.append({header[i]: self._decode_cell(header[i], cells[i]) for i in range(len(header))})
            return rows

    def _write_all(self, rows: list[dict]) -> None:
        with _LOCK:
            lines = [self._header().rstrip("\n")]
            for row in rows:
                cells = [self._encode_cell(c, row.get(c)) for c in self.columns]
                lines.append("| " + " | ".join(cells) + " |")
            tmp = self._path().with_suffix(".md.tmp")
            tmp.write_text("\n".join(lines) + "\n")
            os.replace(tmp, self._path())

    # ── KEY_VALUE ops ────────────────────────────────────────────────────
    def get(self, key: Any) -> Optional[dict]:
        for row in self.read_all():
            if str(row.get(self.pk)) == str(key):
                return row
        return None

    def upsert(self, key: Any, record: dict) -> None:
        with _LOCK:
            rows = self.read_all()
            for i, row in enumerate(rows):
                if str(row.get(self.pk)) == str(key):
                    rows[i] = {**row, **record}
                    self._write_all(rows)
                    return
            rows.append(record)
            self._write_all(rows)

    # ── APPEND_LOG / SEMANTIC ops ────────────────────────────────────────
    def append(self, record: dict) -> int:
        with _LOCK:
            rows = self.read_all()
            rows.append(record)
            self._write_all(rows)
            return len(rows)

    def query(self, limit: int = 100, **filters: Any) -> list[dict]:
        rows = self.read_all()
        if filters:
            rows = [r for r in rows if all(str(r.get(k)) == str(v) for k, v in filters.items())]
        return list(reversed(rows))[:limit]  # newest first

    # ── deletion ─────────────────────────────────────────────────────────
    def clear(self, key: Any = None, **filters: Any) -> int:
        with _LOCK:
            rows = self.read_all()
            if key is None and not filters:
                self._write_all([])
                return len(rows)
            if key is not None:
                kept = [r for r in rows if str(r.get(self.pk)) != str(key)]
            else:
                kept = [r for r in rows if not all(str(r.get(k)) == str(v) for k, v in filters.items())]
            self._write_all(kept)
            return len(rows) - len(kept)
