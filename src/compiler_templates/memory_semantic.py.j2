    def search(self, query: str, top_k: int = 5) -> list[dict]:
        """Return the top_k records most similar to `query` (by `{{ text_field }}`)."""
        rows = _store.read_all()
        scored = [(r, _score(query, str(r.get(_TEXT_FIELD, "")))) for r in rows]
        scored.sort(key=lambda x: x[1], reverse=True)
        return [r for r, s in scored[:top_k] if s > 0]


