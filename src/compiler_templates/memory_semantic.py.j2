def _tokens(text: str) -> set:
    return set(re.findall(r"\w+", (text or "").lower()))


def _score(query: str, text: str) -> float:
    a, b = _tokens(query), _tokens(text)
    if not a or not b:
        return 0.0
    return len(a & b) / len(a | b)


