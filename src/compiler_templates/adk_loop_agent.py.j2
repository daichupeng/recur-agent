"""{{ node.name }} — loop orchestrator."""
from google.adk.agents import LoopAgent
{%- for imp in child_imports %}
from {{ imp.module }} import {{ imp.symbol }}
{%- endfor %}
{%- if memory_node_id %}
from memory._bindings import BEFORE_CALLBACKS, AFTER_CALLBACKS
{%- endif %}

# max_iterations: sub-agent must call actions.escalate() to terminate early.
{{ node.name }}_agent = LoopAgent(
    name="{{ node.name }}",
    max_iterations=10,
    sub_agents=[
{%- for imp in child_imports %}
        {{ imp.symbol }},
{%- endfor %}
    ],
{%- if memory_node_id %}
    before_agent_callback=BEFORE_CALLBACKS.get("{{ memory_node_id }}"),
    after_agent_callback=AFTER_CALLBACKS.get("{{ memory_node_id }}"),
{%- endif %}
)
