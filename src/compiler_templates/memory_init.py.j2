# Registry mapping entity name → its clear_<entity> deletion function (used by the
# --clear-memory CLI flag and the POST /memory/{entity}/clear REST endpoint).
CLEAR_FUNCTIONS = {
{%- for entity in entities %}
    "{{ entity.name }}": clear_{{ entity.table }},
    "{{ entity.table }}": clear_{{ entity.table }},
{%- endfor %}
}


def clear_memory(entity: str | None = None) -> int:
    """Clear one entity (by name or table) or, if entity is None, ALL entities.

    Returns the total number of rows removed.
    """
    if entity is None:
        return sum(fn() for fn in {
{%- for entity in entities %}
            "{{ entity.table }}": clear_{{ entity.table }},
{%- endfor %}
        }.values())
    fn = CLEAR_FUNCTIONS.get(entity)
    if fn is None:
        # Unknown entity → no-op (return 0) rather than raise, so a stray/mistaken call
        # can never crash a caller.
        return 0
    return fn()
